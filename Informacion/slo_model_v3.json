 "metodologia": {
  "componentes": [
   {
    "nombre": "Puntaje curso–dimensión (Cij)",
    "def": "0 = ausente; 1 = introduce; 2 = aplica; 3 = resultado central y evaluable."
   },
   {
    "nombre": "Peso dimensión–SLO (Rjk)",
    "def": "0 = sin relación; 1 = complementaria; 2 = directa; 3 = nuclear."
   },
   {
    "nombre": "Alineación curso–SLO",
    "def": "100 × Σ(Cij × Rjk) ÷ [3 × Σ(Rjk)]. Produce un porcentaje entre 0 y 100."
   },
   {
    "nombre": "Factor de nivel curricular",
    "def": "B = 0.25; I = 0.50; A = 0.75; E = 1.00."
   },
   {
    "nombre": "Factor de evidencia",
    "def": "Directa = 1.00; indirecta = 0.50; sin evidencia = 0."
   },
   {
    "nombre": "Valor efectivo",
    "def": "Créditos × (alineación ÷ 100) × factor de nivel × factor de evidencia."
   },
   {
    "nombre": "Contribución porcentual",
    "def": "Valor efectivo del curso ÷ suma de valores efectivos del SLO."
   },
   {
    "nombre": "Valor normalizado de dimensión",
    "def": "Peso de la dimensión ÷ suma de pesos de todas las dimensiones vinculadas al SLO."
   },
   {
    "nombre": "1.",
    "def": "El porcentaje no sustituye el juicio académico; documenta cómo se obtuvo."
   },
   {
    "nombre": "2.",
    "def": "El tope curricular impide que una materia inicial alcance nivel avanzado por una alta afinidad temática."
   },
   {
    "nombre": "3.",
    "def": "Una materia sin evidencia evaluable no aporta valor efectivo, aunque mencione el tema."
   },
   {
    "nombre": "4.",
    "def": "Los créditos ponderan la exposición curricular, pero no convierten una materia extensa en evidencia de dominio."
   },
   {
    "nombre": "5.",
    "def": "La suma de contribuciones de cada SLO equivale a 100 %, lo cual permite identificar cursos centrales y vacíos."
   },
   {
    "nombre": "6.",
    "def": "Los pesos de Vinculación SLO deben aprobarse mediante criterio colegiado y conservar una justificación documental."
   }
  ],
  "rangos": [
   {
    "rango": "0–19.9",
    "nivel": "Sin asignación",
    "condicion": "No alcanza contribución suficiente."
   },
   {
    "rango": "20–39.9",
    "nivel": "B",
    "condicion": "Introducción o aplicación con guía."
   },
   {
    "rango": "40–59.9",
    "nivel": "I",
    "condicion": "Aplicación en problemas delimitados."
   },
   {
    "rango": "60–79.9",
    "nivel": "A",
    "condicion": "Integración con autonomía."
   },
   {
    "rango": "80–100",
    "nivel": "E",
    "condicion": "Demostración integral en contexto profesional o final."
   }
  ],
  "reglas": []
 }
